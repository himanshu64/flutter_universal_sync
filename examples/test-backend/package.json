{
  "name": "flutter-universal-sync-test-backend",
  "version": "0.1.0",
  "description": "Local test backend for the flutter_universal_sync REST adapter — Express + better-sqlite3.",
  "private": true,
  "type": "commonjs",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
